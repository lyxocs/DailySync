# =============================================
# Garmin DailySync 环境变量配置
# 复制此文件为 .env 并填写你的账号信息
# =============================================

# 佳明中国区账号
GARMIN_USERNAME=
GARMIN_PASSWORD=

# 佳明国际区账号
GARMIN_GLOBAL_USERNAME=
GARMIN_GLOBAL_PASSWORD=

# Session 加密密钥（可自定义，修改后需清空 db/garmin.db 重新登录）
AESKEY=LSKDAJALSD

# 迁移历史数据配置（仅 migrate 命令使用）
GARMIN_MIGRATE_NUM=100
GARMIN_MIGRATE_START=0

# =============================================
# 以下为可选配置
# =============================================

# Bark 推送通知 Key（可选）
BARK_KEY=

# Google Sheets 集成（可选，RQ 数据记录使用）
GOOGLE_SHEET_ID=
GOOGLE_API_CLIENT_EMAIL=
GOOGLE_API_PRIVATE_KEY=

# RQ 跑力采集（可选）
RQ_USERID=
RQ_COOKIE=
RQ_CSRF_TOKEN=
RQ_USERNAME=
RQ_PASSWORD=

# Strava 集成（可选）
STRAVA_ACCESS_TOKEN=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=
